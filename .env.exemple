# Voice Assistant - Configuração de Ambiente
# ==========================================
# Copie este arquivo para .env e preencha com suas credenciais

# OpenAI API Key (obrigatório)
# -----------------------------
# Obtenha em: https://console.groq.com/keys
GROQ_API_KEY=sua_chave_aqui

# Configurações Opcionais
# ------------------------
# Modelo ChatGPT (padrão: gpt-4o-mini)
# CHATGPT_MODEL=gpt-4o-mini

# Idioma padrão (padrão: pt)
# DEFAULT_LANGUAGE=pt

# Velocidade de fala reduzida (padrão: false)
# TTS_SLOW_SPEED=false

# Duração máxima de gravação em segundos (padrão: 10)
# MAX_RECORD_SECONDS=10

# Número máximo de turnos no histórico (padrão: 10)
# MAX_HISTORY_TURNS=10
